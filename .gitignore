*.py[cod]
*$py.class
*.pyo
*.pyd
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# 2. Virtual environment
venv/
env/
.env/
.venv/
ENV/
env.bak/
