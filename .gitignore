# 2.1 Secrets and environment variables
.env
.env.local
.env.*.local
*.env
auth.json
secrets.json

# 3. Logs
logs/
*.log

# 4. Memory / Data / Database files
memory/chroma_db/
memory/memory.json
memory/*.db
reminders/reminders.json
db.sqlite3
*.db
*.sqlite

# 5. OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
Thumbs.db

