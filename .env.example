# ============================================================
# Wednesday — Environment Variables
# ============================================================
# Copy this file:   copy .env.example .env
# Fill in ONE free API key below, then run: python main.py
# ============================================================

# ══════════════════════════════════════════════════════════════
#  FREE OPTIONS — No credit card needed
# ══════════════════════════════════════════════════════════════

# ── OPTION 1: Groq (RECOMMENDED — fastest + free) ───────────
# 1. Go to:  https://console.groq.com
# 2. Sign up with Google or email (free)
# 3. Click "API Keys" → "Create API Key"
# 4. Paste the key below:
GROQ_API_KEY=gsk_...

# ── OPTION 2: Google Gemini (1M tokens/day free) ────────────
# 1. Go to:  https://aistudio.google.com/app/apikey
# 2. Sign in with your Google account
# 3. Click "Create API Key"
# 4. Paste the key below:
GEMINI_API_KEY=AIza...

# ── OPTION 3: Ollama (100% local, no internet needed) ───────
# No key needed! Just:
# 1. Download Ollama: https://ollama.com/download
# 2. Install it and run the app
# 3. Open PowerShell: ollama pull llama3
# 4. Set in config.yaml:  llm.provider: ollama
# (leave keys blank)

# ══════════════════════════════════════════════════════════════
#  PAID OPTIONS (skip if using free options above)
# ══════════════════════════════════════════════════════════════

# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic Claude (paid): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ══════════════════════════════════════════════════════════════
#  OPTIONAL EXTRAS
# ══════════════════════════════════════════════════════════════

# ElevenLabs (better voice — 10k chars/month free)
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Porcupine wake word (free single device)
# https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=...
